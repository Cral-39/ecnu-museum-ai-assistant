    {
        "藏品序列号": "602",
        "中文名": "乾隆通宝",
        "英文名": "Qianlong Tongbao",
        "保藏地点": "古钱币博物馆",
        "尺寸": "外径2.7cm，内径0.6cm",
        "材质": "铜",
        "时代": "清 乾隆年间（1736–1796 CE）",
        "简述": "乾隆通宝，直读，背面满文左右分别为“宝”“泉”，即宝泉局所铸。此枚钱币比一般小平钱略大，在已铸成钱币上再加工，手工刻琢各种花纹、精美图案或吉语文字构成纹饰，又称“刻花钱”，属于民俗钱。其本身为流通货币，刻花后多作配饰或观赏，不再流通。正面“乾”上方为“寿”字，“隆”下方为桃形纹饰，象征长寿。其余图案为道教八宝（暗八仙纹），暗八仙纹始盛于清康熙朝，流行于整个清代。此枚仅含四者，应与另一枚成对。",
        "收入出版物": "《华东师范大学博物馆精品图集（一）》",
        "image_urls": ["https://digitalmuseum.ecnu.edu.cn/_upload/article/images/39/94/777c89ff431db2ae92a722c35ddd/24f481ac-47b7-4e30-a9e2-8f8fd9389ae7.jpg","https://digitalmuseum.ecnu.edu.cn/_upload/article/images/39/94/777c89ff431db2ae92a722c35ddd/712d3318-bb15-45d6-a12e-19799165c2e3.jpg"]
